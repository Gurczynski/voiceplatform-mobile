# OhTry Mobile - Environment Configuration
# Copy this file to .env and fill in your values

# Supabase (get from supabase.com dashboard)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Twilio (get from console.twilio.com)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SECRET=your-api-key-secret

# Stripe (get from dashboard.stripe.com)
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxx

# AI (get from ollama.com or use OpenAI)
OLLAMA_API_KEY=your-ollama-api-key
OLLAMA_API_URL=https://api.ollama.com

# Email (get from resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx

# App Configuration
APP_URL=https://ohtry.com
APP_NAME=OhTry Mobile
